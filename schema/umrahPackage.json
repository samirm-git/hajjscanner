{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "umrahPackage.json",
  "title": "Package",
  "description": "Umrah package details",
  "type": "object",
  "properties": {
    "company":{
    "description": "company name",
    "type": "string"
    },
    "url":{
      "description": "url to package details",
      "type": "string",
      "format": "uri"
    },
    "ppp" : {
      "description": "price per person in £", 
      "type": ["integer", "null"],
      "minimum": 100,
      "maximum": 10000,
      "minItems": 1
      },
    "year":{
      "description": "year in which package is offered",
      "type": ["integer", "null"],
      "minimum": 2020
    },
    "season":{
      "description": "season when the package is offered",
      "type": ["string", "null"],
      "enum": ["Winter", "Spring", "Summer", "Autumn", null]
    },
    "month":{
      "description": "month in which the package is offered",
      "type": ["string", "null"],
      "enum": ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December", null]
    },
    "islamicMonth":{
      "description": "islamic month in which package is offered",
      "type": ["string", "null"],
      "enum": ["Muharram", "Safar", "Rabi' al-Awwal", "Rabi' al-Thani", "Jumada al-Ula", "Jumada al-Akhirah", "Rajab", "Sha'ban", "Ramadan", "Shawwal", "Dhu al-Qa'dah", "Dhu al-Hijjah", null]
    },
    "total_days":{
      "description": "total number of days in package",
      "type": ["integer", "null"],
      "minimum": 5,
      "maximum": 30
    },
    "tier":{
      "description": "type of hajj package: luxury, premium, or economy",
      "type": ["string", "null"],
      "enum": ["luxury", "premium", "economy", null]
    },
    "stars":{
      "description": "star rating (1-5)",
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5,
      "minItems": 1
    },
    "departureCity":{
      "description": "The deparature city where the umrah is being offered from.",
      "type": ["string", "null"]
    },
    "isVisaIncluded":{
      "description": "True if visa included in package, False if visa not included",
      "type": ["boolean", "null"]
    },
    "isZiyaratIncluded":{
      "description": "Is guided tours of religious sites included in the package",
      "type": ["boolean", "null"]
    },
    "makkahHotel": {
      "description": "Makkah hotel details",
      "$ref": "hotel.json"
    },
    "madinahHotel":{
      "description": "Madinah hotel details",
      "$ref": "hotel.json"
    }
  },
  "required": ["company","ppp", "year", "season", "month", "islamicMonth", "total_days", "stars", "departureCity", "isVisaIncluded", "isZiyaratIncluded", "makkahHotel", "madinahHotel"]
}