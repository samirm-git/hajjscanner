 { 
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "hotel.json",
  "title": "Hotel",
  "type": "object",
  "properties": {
      "nights": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "name": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100
      },
      "images": {
        "type": "array",
        "items": { "type": "string", "format": "uri" },
        "minItems": 1,
        "uniqueItems": true
      },
      "stars": {
        "type": "integer",
        "description": "hotel star rating from 1 to 5",
        "minimum": 1,
        "maximum": 5
      },
      "hasFreeWifi":{
        "type":"boolean",
        "description": "True if hotel provides free wifi. False otherwise"
      },
      "hasAC":{
        "type":"boolean",
        "description": "True if hotel room has air conditioning (AC). False otherwise"
      },
      "otherAmenities":{
        "type":"string",
        "description": "Description of any other amenities the hotel provides"
      },
      "distanceToHaram": {
        "description": "distance to the haram in meters",
        "type": "number",
        "minimum": 1
      },
      "walkToHaram": {
        "description": "time taken to walk to the haram in minutes",
        "type": "number",
        "minimum": 1
      },
      "numberOfBeds":{
        "description": "number of beds in hotel room",
        "type": "number",
        "minimum": 1
      }
      },
      "required": ["name"]
    }
      