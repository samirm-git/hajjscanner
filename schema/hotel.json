 { 
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "hotel.json",
  "title": "Hotel",
  "type": ["object", "null"],
  "properties": {
      "name": {
        "type": ["string", "array","null"],
        "minLength": 2,
        "maxLength": 100,
        "minItems": 1
      },
      "total_days": {
        "type": ["integer", "array", "null"],
        "minimum": 1,
        "maximum": 20,
        "minItems": 1
      },
      "images": {
        "type": ["array", "null"],
        "items": { "type": "string", "format": "uri" },
        "minItems": 1,
        "uniqueItems": true
      },
      "stars": {
        "type": ["integer", "array", "null"],
        "description": "hotel star rating from 1 to 5",
        "minimum": 1,
        "maximum": 5,
        "minItems": 1
      },
      "hasWifi":{
        "type":["boolean", "null"],
        "description": "True if hotel provides wifi. False otherwise"
      },
      "hasAC":{
        "type":["boolean", "null"],
        "description": "True if hotel room has air conditioning (AC). False otherwise"
      },
      "otherAmenities":{
        "type":["string", "null"],
        "description": "Description of any other amenities the hotel provides"
      },
      "distanceToHaram": {
        "description": "distance to the haram in meters",
        "type": ["number", "array", "null"],
        "minimum": 500,
        "maximum": 4000,
        "minItems": 1
      },
      "walkToHaram": {
        "description": "time taken to walk to the haram in minutes",
        "type": ["number", "array", "null"],
        "minimum": 2,
        "maximum": 40,
        "minItems": 1
      },
      "driveToHaram":{
        "description": "time taken to drive to haram in minutes",
        "type": ["number", "array", "null"],
        "minimum": 1,
        "maximum": 10,
        "minItems":1
      },
      "numberOfBeds":{
        "description": "number of beds in hotel room",
        "type": ["number", "array", "null"],
        "minimum": 1,
        "maximum": 6,
        "minItems":1
      }
      },
      "required": ["total_days", "name", "images", "stars", "hasWifi", "hasAC", "distanceToHaram", "walkToHaram", "numberOfBeds"]
    }
      