{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "hajjPackage.json",
  "title": "Package",
  "description": "Hajj package details",
  "type": "object",
  "properties": {
    "company":{
    "description": "company name",
    "type": "string"
    },
    "url":{
      "description": "url to package details",
      "type": "string",
      "format": "uri"
    },
    "ppp" : {
      "description": "price per night in £", 
      "type": ["integer", "null"],
      "minimum": 2000,
      "maximum": 25000,
      "minItems": 1
      },
    "total_days":{
      "description": "total number of days in package",
      "type": ["integer", "null"],
      "minimum": 10,
      "maximum": 30,
      "minItems": 1
    },
    "tier":{
      "description": "type of hajj package: luxury, premium, or economy",
      "type": ["string", "null"],
      "enum": ["luxury", "premium", "economy"],
      "minItems": 1
    },
    "stars":{
      "description": "star rating (1-5)",
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5,
      "minItems": 1
    },
    "isShifting":{
      "description": "True if shifting package, False if non shifting",
      "type": ["boolean", "null"]
    },
    "makkahHotel": {
      "description": "Makkah hotel details",
      "$ref": "hotel.json"
    },
    "madinahHotel":{
      "description": "Madinah hotel details",
      "$ref": "hotel.json"
    },
    "isVisaIncluded":{
      "description": "True if visa included in package, False if visa not included",
      "type": ["boolean", "null"]
    }
  },
  "required": ["company","ppp", "total_days", "stars", "isShifting", "makkahHotel", "madinahHotel", "isVisaIncluded"]
}